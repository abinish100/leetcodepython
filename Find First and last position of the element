class Solution(object):
    def searchRange(self, nums, target):
        n1=[]
        n=[]
        if target in nums:
            for i in range(len(nums)):
                if nums[i]==target :
                    n1.append(i)
            if len(n1)==1:
                n1.append(n1[0])
                return n1
            else:
                n1.sort()
                n.append(n1[0])
                n.append(n1[-1])
                return n

        else:
            return [-1, -1]
